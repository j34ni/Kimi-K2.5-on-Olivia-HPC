Bootstrap: docker
From: nvidia/cuda:12.6.3-cudnn-devel-ubuntu24.04

%post
    apt-get update && apt-get install -y wget git autoconf automake libtool && rm -rf /var/lib/apt/lists/*

    wget -q https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-aarch64.sh -O /tmp/miniforge.sh
    bash /tmp/miniforge.sh -b -p /opt/conda
    rm /tmp/miniforge.sh

    /opt/conda/bin/conda install -y -c conda-forge gcc_linux-aarch64 gxx_linux-aarch64 "mvapich=4.1=shs_cuda_hb5d4c84_12" ninja python=3.12

    git clone --depth 1 --branch v1.17.0 https://github.com/aws/aws-ofi-nccl.git /opt/uio/aws-ofi-nccl
    cd /opt/uio/aws-ofi-nccl
    ./autogen.sh
    ./configure --with-libfabric=/opt/conda --with-cuda=/usr/local/cuda --with-nccl=/usr/local/cuda --prefix=/opt/conda
    make -j$(nproc)
    make install
    cd / && rm -rf /opt/uio/aws-ofi-nccl

    /opt/conda/bin/pip install sglang --extra-index-url https://download.pytorch.org/whl/cu126

    ln -sf /usr/local/cuda/bin/nvcc /opt/conda/bin/nvcc
    mkdir -p /opt/conda/targets/sbsa-linux
    ln -sfn /usr/local/cuda/bin      /opt/conda/targets/sbsa-linux/bin
    ln -sfn /usr/local/cuda/include  /opt/conda/targets/sbsa-linux/include
    ln -sfn /usr/local/cuda/lib      /opt/conda/targets/sbsa-linux/lib
    ln -sfn /usr/local/cuda/lib64    /opt/conda/targets/sbsa-linux/lib64
    ln -sf /usr/local/cuda/targets/sbsa-linux/include/fatbinary_section.h /usr/include/fatbinary_section.h

    /opt/conda/bin/conda clean -afy

%environment
    export PATH=/usr/local/cuda/nvvm/bin:/usr/local/cuda/bin:/opt/conda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:/usr/local/cuda/lib:/opt/conda/lib:$LD_LIBRARY_PATH
    export CUDA_HOME=/usr/local/cuda
    export CPATH=/opt/conda/targets/sbsa-linux/include:${CPATH}
    export FI_PROVIDER=cxi
    export MPICH_CH4_NETMOD=ofi
    export NCCL_NET="AWS Libfabric"
    export NCCL_SOCKET_IFNAME=hsn
    export NCCL_NET_GDR_LEVEL=PHB
    export NCCL_CROSS_NIC=1
    export NCCL_PROTO=^LL128
    export FI_CXI_DEFAULT_CQ_SIZE=131072
    export FI_CXI_DEFAULT_TX_SIZE=16384
    export FI_CXI_DISABLE_HOST_REGISTER=1
    export FI_CXI_RX_MATCH_MODE=software
    export FI_MR_CACHE_MONITOR=userfaultfd
    export MV2_ENABLE_AFFINITY=0

%labels
    Model moonshotai/Kimi-K2.5
    Network Slingshot-11 / CXI / mvapich-4.1-shs_cuda / shs-libfabric-2.2.0 / aws-ofi-nccl-1.17.0
